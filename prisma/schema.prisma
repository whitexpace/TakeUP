generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ItemCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum ItemCategory {
  ELECTRONICS
  BOOKS
  CLOTHING
  TOOLS
  HOME_APPLIANCES
  SPORTS_OUTDOORS
  MUSIC_AUDIO
  TOYS_GAMES
  FURNITURE
  VEHICLES_ACCESSORIES
  HEALTH_BEAUTY
  SCHOOL_SUPPLIES
  PET_SUPPLIES
  OTHER
}

model Item {
  id          String   @id @default(uuid())
  name        String
  description String?
  condition   ItemCondition
  category    ItemCategory

  rentalFee   Int
  availabilityDates DateTime[]
  freeToBorrow Boolean

  photos      String[]

  lenderId    String
  borrowerId  String?

  lender      Lender     @relation(fields: [lenderId], references: [userId], onDelete: Cascade)
  borrower    Borrower?  @relation(fields: [borrowerId], references: [userId], onDelete: SetNull)

  @@index([lenderId])
  @@index([borrowerId])
}

model User {
  id         String  @id @default(uuid())
  username   String
  email      String  @unique
  firstName  String
  middleName String?
  lastName   String
  googleSub  String  @unique

  accountType AccountType
  status      UserStatus

  points Int @default(0)

  lender   Lender?
  borrower Borrower?
  admin    Admin?
}

model Admin {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role        String
  accessLevel Int
}

model Lender {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  lenderRating Int @default(0)

  listedItem  Item[]
}

model Borrower {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  borrowStatus   String
  borrowerRating Int    @default(0)

  borrowedItems   Item[]
}

enum AccountType {
  LENDER
  BORROWER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}
