generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum ItemCategory {
  ELECTRONICS
  BOOKS
  CLOTHING
  TOOLS
  HOME_APPLIANCES
  SPORTS_OUTDOORS
  MUSIC_AUDIO
  TOYS_GAMES
  FURNITURE
  VEHICLES_ACCESSORIES
  HEALTH_BEAUTY
  SCHOOL_SUPPLIES
  PET_SUPPLIES
  OTHER
}

enum ItemAvailabilityStatus {
  AVAILABLE
  RENTED
}

enum ItemStatus {
  AVAILABLE
  RENTED
  DEACTIVATED
  DELETED
}

enum RateOption {
  PER_HOUR
  PER_DAY
}

model Item {
  id          String        @id @default(uuid())
  name        String
  description String?
  condition   ItemCondition
  status      ItemStatus    @default(AVAILABLE)
  rateOption  RateOption    @default(PER_DAY)
  createdAt   DateTime      @default(now())

  rentalFee       Int
  replacementCost Int?
  freeToBorrow    Boolean
  availability    ItemAvailability[]

  whatItemOffers   String?
  whatIsIncluded   String?
  knownIssues      String?
  usageLimitations String?

  thumbnailImage String?
  photos         String[]
  categories     ItemCategoryOnItem[]
  tags           ItemTagOnItem[]
  likes          Like[]

  isTrending   Boolean @default(false)
  viewCount    Int     @default(0)
  bookingCount Int     @default(0)
  likeCount    Int     @default(0)
  rating       Float   @default(0)

  lenderId   String
  borrowerId String?

  lender   Lender    @relation(fields: [lenderId], references: [userId], onDelete: Cascade)
  borrower Borrower? @relation(fields: [borrowerId], references: [userId], onDelete: SetNull)

  @@index([lenderId])
  @@index([borrowerId])
}

model ItemAvailability {
  id        String                 @id @default(uuid())
  itemId    String
  startDate DateTime
  endDate   DateTime
  status    ItemAvailabilityStatus
  createdAt DateTime               @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, startDate, endDate])
  @@index([itemId])
  @@index([itemId, status])
  @@index([startDate, endDate])
}

model ItemCategoryOnItem {
  itemId    String
  category  ItemCategory
  createdAt DateTime     @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([itemId, category])
  @@index([category])
}

model Tag {
  id    String          @id @default(uuid())
  name  String          @unique
  items ItemTagOnItem[]
}

model ItemTagOnItem {
  itemId String
  tagId  String

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
  @@index([tagId])
}

model User {
  id         String  @id @default(uuid())
  username   String
  email      String  @unique
  firstName  String
  middleName String?
  lastName   String
  googleSub  String  @unique

  accountType AccountType
  status      UserStatus

  points Int @default(0)

  likes Like[]

  lender   Lender?
  borrower Borrower?
  admin    Admin?
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  itemId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
}

model Admin {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role        String
  accessLevel Int
}

model Lender {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  lenderRating Int @default(0)

  listedItem Item[]
}

model Borrower {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  borrowStatus   String
  borrowerRating Int    @default(0)

  borrowedItems Item[]
}

enum AccountType {
  LENDER
  BORROWER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}
