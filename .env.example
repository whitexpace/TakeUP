# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Prisma
# Use Supabase pooler URL for normal queries (port 6543)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Optional: direct DB URL for Prisma migrations (port 5432).
# If this host is unreachable from your network, run migrations with DATABASE_URL only.
DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/db

# Auth
GOOGLE_CLIENT_ID=
NUXT_PUBLIC_GOOGLE_CLIENT_ID=
JWT_SECRET=

# DATABASE_URL=postgresql://postgres.tlnqvhmrgbwpcopltlwr:PLo$Ob1*E0t*dV@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
